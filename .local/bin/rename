
#!/usr/bin/env bash

for f in *.mkv; do
    new="$f"
    new=$(printf "%s\n" "$new" |
          awk '{ sub(/^www[^-]+-[[:space:]]*/, ""); split($0,a,"-"); print a[1] ".mkv" }' | sed 's/ /_/g')

    if [[ "$f" != "$new" ]]; then
        echo "Renaming:"
        echo "  $f"
        echo "  → $new"
        mv -n -- "$f" "$new"
    fi
done
